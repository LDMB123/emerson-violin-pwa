{
  "name": "panda-violin-pwa",
  "version": "2.0.0",
  "description": "Local-first violin teaching PWA for children with a Red Panda coach and iPadOS 26.2 optimization",
  "keywords": [
    "pwa",
    "violin",
    "music-education",
    "offline-first",
    "react",
    "vite"
  ],
  "homepage": "https://github.com/LDMB123/emerson-violin-pwa#readme",
  "bugs": {
    "url": "https://github.com/LDMB123/emerson-violin-pwa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LDMB123/emerson-violin-pwa.git"
  },
  "packageManager": "npm@11.11.0",
  "type": "module",
  "scripts": {
    "runtime:check": "node scripts/assert-runtime-versions.mjs",
    "preinstall": "npm run runtime:check",
    "predev": "npm run runtime:check && node scripts/build-sw-assets.js",
    "dev": "vite",
    "preoptimize": "node scripts/optimize-images.js && node scripts/optimize-audio.js && node scripts/optimize-fonts.js",
    "prebuild": "npm run runtime:check && npm run preoptimize && node scripts/build-sw-assets.js",
    "build": "vite build",
    "postbuild": "node scripts/build-spa-fallback.mjs && node scripts/build-sw-assets.js --dist",
    "preview": "vite preview",
    "pretest": "npm run runtime:check",
    "test": "vitest run",
    "pretest:watch": "npm run runtime:check",
    "test:watch": "vitest",
    "pretest:coverage": "npm run runtime:check",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "npm run runtime:check",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test -c playwright.live.config.js tests/e2e/live-site-smoke.spec.js",
    "qa:effectiveness": "npm run test:coverage && node scripts/assert-critical-coverage.mjs",
    "lint": "eslint src --ext .js",
    "lint:all": "eslint src scripts tests --ext .js,.mjs --ignore-pattern 'src/wasm/**'",
    "audit:dup": "jscpd src tests wasm --config .jscpd.json",
    "audit:deadcode": "knip --include files,dependencies,exports,duplicates --no-progress",
    "audit:deps": "node scripts/audit-dependency-duplicates.mjs",
    "audit:feature-parity": "node scripts/audit-feature-parity.mjs",
    "audit:secrets": "node scripts/audit-secrets.mjs",
    "audit:release-tests": "node scripts/audit-release-test-gates.mjs",
    "audit:docs": "node scripts/audit-docs.mjs",
    "audit:static": "node scripts/audit-secrets.mjs && node scripts/audit-docs.mjs && node scripts/audit-dependency-duplicates.mjs && node scripts/audit-performance-budget-config.mjs && node scripts/audit-feature-parity.mjs && node scripts/audit-release-test-gates.mjs && node scripts/audit-accessibility.mjs && node scripts/audit-learning-completeness.mjs",
    "audit:perf": "node scripts/audit-performance-budgets.mjs",
    "audit:perf:config": "node scripts/audit-performance-budget-config.mjs",
    "audit:perf:recommend": "node scripts/recommend-performance-budgets.mjs",
    "audit:perf:summary": "node scripts/render-performance-recommendation-summary.mjs",
    "audit:perf:apply": "node scripts/apply-performance-recommendation.mjs",
    "audit:a11y": "node scripts/audit-accessibility.mjs",
    "audit:learning": "node scripts/audit-learning-completeness.mjs",
    "preaudit:dep-backed": "npm run runtime:check",
    "audit:dep-backed": "npm run lint:all && npm run audit:dup && npm run audit:deadcode && npm run qa:effectiveness && npm run build",
    "preaudit:full": "npm run runtime:check",
    "audit:full": "npm run audit:static && npm run audit:dep-backed",
    "prehandoff:verify": "npm run runtime:check",
    "handoff:verify": "npm run audit:full && npm run test:e2e",
    "handoff:status": "node scripts/handoff-status.mjs",
    "qa:screenshots": "node scripts/qa-screenshots.mjs",
    "stash:audit": "node scripts/stash-audit.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "fluent-ffmpeg": "^2.1.3",
    "happy-dom": "^20.8.3",
    "jscpd": "^4.0.8",
    "knip": "^5.85.0",
    "sharp": "^0.34.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "25.8.0",
    "npm": "11.11.0"
  },
  "dependencies": {
    "@sentry/react": "^10.42.0",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  }
}
