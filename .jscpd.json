{
  "threshold": 0,
  "reporters": [
    "console",
    "json"
  ],
  "output": ".jscpd",
  "gitignore": true,
  "minLines": 5,
  "minTokens": 50,
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.tmp/**",
    "**/src/wasm/**",
    "**/wasm/*/pkg/**",
    "**/wasm/target/**",
    "**/src/views/**/*.jsx",
    "**/src/hooks/useGameSort.js",
    "**/src/hooks/useNativeSongPlayer.js",
    "**/src/hooks/useMediaRecorder.js",
    "**/src/app/game-sort-controller.js"
  ]
}